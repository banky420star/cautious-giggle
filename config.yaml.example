trading:
  symbols: ["EURUSDm", "GBPUSDm", "XAUUSDm"]
  timeframe: "M5"
  risk_percent: 1.0
  max_drawdown: 10.0
  confidence_threshold: 0.85
  magic_number: 505

risk:
  max_daily_loss: 1000
  max_daily_trades: 500
  max_daily_trades_per_symbol: 50
  max_daily_losing_trades_per_symbol: 10
  max_lots: 1.0

telegram:
  token: "YOUR_BOT_TOKEN_HERE"
  chat_id: "YOUR_CHAT_ID_HERE"

event_intel:
  enabled: true
  poll_sec: 60
  pre_event_min: 60
  post_event_min: 30
  news_hold_min: 20
  max_events: 200
  # Optional feeds:
  # calendar_url: "https://your-calendar-feed/events"
  # news_url: "https://your-news-feed/headlines"
  # websocket_url: "wss://your-feed/ws"

drl:
  total_timesteps: 500000
  per_symbol: true
  period: "90d"
  interval: "M5"
  candles_per_symbol: 100000
  eval_period: "120d"
  model_path: "models/ppo_trading.zip"
  reward:
    version: "v2_risk_adjusted"
    weights:
      growth: 8.0
      payoff: 2.0
      sharpe_bonus: 1.0
      drawdown_penalty: 3.0
      cost_penalty: 5.0
      churn_penalty: 0.5
      memory_expectancy_bonus: 0.5
      loss_streak_penalty: 0.4

training:
  lstm_epochs: 20
  per_symbol: true
  lstm_period: "90d"
  lstm_interval: "M5"
  lstm_candles: 100000

evaluation:
  max_drawdown: 0.10
  min_sharpe: 0.30
  min_return: 0.015
  score_margin: 0.30
  min_steps_per_symbol: 600
  min_pass_rate: 0.80
  return_margin: 0.0
  sharpe_margin: 0.05
  drawdown_margin: 0.0
  forward_windows: ["60d", "90d", "120d"]
  min_forward_win_rate: 0.67

registry:
  canary_policy:
    default:
      min_trades: 30
      min_realized_pnl: 0.0
      max_drawdown: 0.12
      min_runtime_minutes: 45
    per_symbol:
      EURUSDm:
        max_drawdown: 0.15
        min_trades: 40
      BTCUSDm:
        max_drawdown: 0.08
        min_trades: 60

