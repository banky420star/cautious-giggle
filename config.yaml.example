trading:
  symbols: ["EURUSDm", "GBPUSDm", "XAUUSDm"]
  timeframe: "M5"
  risk_percent: 1.0
  max_drawdown: 10.0
  confidence_threshold: 0.85
  magic_number: 505

telegram:
  token: "YOUR_BOT_TOKEN_HERE"
  chat_id: "YOUR_CHAT_ID_HERE"

drl:
  total_timesteps: 500000
  per_symbol: true
  period: "90d"
  interval: "M5"
  candles_per_symbol: 500000
  eval_period: "120d"
  model_path: "models/ppo_trading.zip"
  reward:
    version: "v2_risk_adjusted"
    weights:
      growth: 8.0
      payoff: 2.0
      sharpe_bonus: 1.0
      drawdown_penalty: 3.0
      cost_penalty: 5.0
      churn_penalty: 0.5

training:
  lstm_epochs: 20
  per_symbol: true
  lstm_period: "90d"
  lstm_interval: "M5"
  lstm_candles: 500000

evaluation:
  max_drawdown: 0.10
  min_sharpe: 0.30
  min_return: 0.015
  score_margin: 0.30
  min_steps_per_symbol: 600
  min_pass_rate: 0.80
  return_margin: 0.0
  sharpe_margin: 0.05
  drawdown_margin: 0.0
  forward_windows: ["60d", "90d", "120d"]
  min_forward_win_rate: 0.67
